# === NOMBA INTEGRATION ===
NOMBA_PROVIDER=live # 'live' or 'mock'
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_ACCOUNT_ID=your_account_id_here
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id_here
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here
NOMBA_WEBHOOK_SECRET=your_webhook_secret_here

# === MOCK CONTROLS ===
NOMBA_MOCK_OUTAGE=false
NOMBA_MOCK_LATENCY_MS=500

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
